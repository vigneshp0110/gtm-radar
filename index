<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GTM Radar</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    /* ── Reset & Base ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:          #02020a;
      --surface:     #05050f;
      --card:        #07071a;
      --card-hover:  #0a0a20;
      --border:      #141430;
      --border-hover:rgba(0,212,255,.35);
      --primary:     #00d4ff;
      --primary-dim: rgba(0,212,255,.08);
      --primary-glow:rgba(0,212,255,.18);
      --accent:      #a855f7;
      --accent-glow: rgba(168,85,247,.18);
      --green:       #00ff88;
      --text:        #dce8ff;
      --text-2:      #7a8fbb;
      --muted:       #3a4468;
      --subtle:      #0f1030;
    }

    /* ── Scrollbar ── */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--muted); border-radius: 99px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--primary); }

    /* ── Dot-grid background ── */
    body {
      background-color: var(--bg);
      background-image: radial-gradient(circle, rgba(0,212,255,.06) 1px, transparent 1px);
      background-size: 28px 28px;
      color: var(--text);
      font-family: 'Space Grotesk', -apple-system, BlinkMacSystemFont, sans-serif;
      min-height: 100vh;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; text-decoration: none; }
    button { cursor: pointer; border: none; background: none; color: inherit; font: inherit; }

    /* ── Keyframes ── */
    @keyframes radar-spin {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }
    @keyframes pulse-ring {
      0%   { box-shadow: 0 0 0 0 rgba(0,212,255,.45); }
      70%  { box-shadow: 0 0 0 8px rgba(0,212,255,0); }
      100% { box-shadow: 0 0 0 0 rgba(0,212,255,0); }
    }
    @keyframes scan-line {
      0%   { opacity: 0; top: 0; }
      10%  { opacity: 1; }
      90%  { opacity: 1; }
      100% { opacity: 0; top: 100%; }
    }
    @keyframes flicker {
      0%,100% { opacity: 1; } 92% { opacity: 1; } 93% { opacity: .6; } 94% { opacity: 1; }
    }

    /* ── Header ── */
    header {
      position: sticky; top: 0; z-index: 100;
      background: rgba(2,2,10,.9);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      padding: 0 24px;
      display: flex; align-items: center; gap: 16px;
      height: 56px;
      box-shadow: 0 1px 0 rgba(0,212,255,.08), 0 4px 32px rgba(0,0,0,.4);
    }
    /* subtle scan line on header */
    header::after {
      content: ''; pointer-events: none;
      position: absolute; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, var(--primary), transparent);
      bottom: -1px; opacity: .4;
    }

    .logo {
      font-weight: 700; font-size: 15px; letter-spacing: .04em;
      color: var(--text); white-space: nowrap;
      display: flex; align-items: center; gap: 10px;
      text-transform: uppercase;
      animation: flicker 8s infinite;
    }
    .logo-icon {
      width: 30px; height: 30px; border-radius: 50%;
      border: 1.5px solid var(--primary);
      display: flex; align-items: center; justify-content: center;
      position: relative; overflow: hidden;
      box-shadow: 0 0 12px rgba(0,212,255,.4), inset 0 0 8px rgba(0,212,255,.1);
      animation: pulse-ring 3s ease-out infinite;
      flex-shrink: 0;
    }
    .logo-icon::before {
      content: '';
      position: absolute;
      width: 200%; height: 2px;
      background: linear-gradient(90deg, transparent, var(--primary), transparent);
      top: 50%; left: -50%;
      transform-origin: center center;
      animation: radar-spin 3s linear infinite;
    }
    .logo-icon svg { color: var(--primary); position: relative; z-index: 1; }
    .logo-text { color: var(--primary); }
    .logo-sub { color: var(--text-2); font-weight: 500; }

    .search-wrap { flex: 1; max-width: 360px; position: relative; }
    .search-wrap svg {
      position: absolute; left: 11px; top: 50%; transform: translateY(-50%);
      color: var(--muted); pointer-events: none;
    }
    .search-wrap input {
      width: 100%; padding: 7px 12px 7px 34px;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 4px; color: var(--text); font-size: 12px;
      font-family: 'JetBrains Mono', monospace; outline: none;
      transition: border-color .2s, box-shadow .2s;
      letter-spacing: .02em;
    }
    .search-wrap input:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 3px var(--primary-glow), 0 0 16px rgba(0,212,255,.1);
    }
    .search-wrap input::placeholder { color: var(--muted); font-family: 'JetBrains Mono', monospace; }

    .header-right { margin-left: auto; display: flex; align-items: center; gap: 8px; }
    .pill-btn {
      display: flex; align-items: center; gap: 6px;
      padding: 6px 12px; border-radius: 4px; font-size: 11px; font-weight: 600;
      border: 1px solid var(--border); background: var(--surface);
      color: var(--text-2); transition: all .2s; letter-spacing: .07em;
      text-transform: uppercase; font-family: 'JetBrains Mono', monospace;
    }
    .pill-btn:hover { border-color: rgba(0,212,255,.3); color: var(--text); }
    .pill-btn.active {
      background: var(--primary-dim); border-color: rgba(0,212,255,.5);
      color: var(--primary);
      box-shadow: 0 0 12px rgba(0,212,255,.15), inset 0 0 8px rgba(0,212,255,.05);
    }
    #postCount {
      font-size: 11px; color: var(--muted); font-family: 'JetBrains Mono', monospace;
      letter-spacing: .04em;
    }

    /* ── App body ── */
    .app-body { display: flex; align-items: flex-start; }

    /* ── Sidebar ── */
    .sidebar {
      position: sticky; top: 56px;
      width: 200px; flex-shrink: 0;
      height: calc(100vh - 56px);
      overflow-y: auto;
      background: rgba(5,5,15,.8);
      border-right: 1px solid var(--border);
      padding: 18px 10px;
      display: flex; flex-direction: column; gap: 2px;
    }
    .sidebar-label {
      font-size: 9px; font-weight: 600; text-transform: uppercase;
      letter-spacing: .15em; color: var(--muted);
      padding: 0 10px; margin-bottom: 10px; margin-top: 4px;
      font-family: 'JetBrains Mono', monospace;
    }
    .sidebar .tab {
      width: 100%; text-align: left;
      padding: 7px 10px; border-radius: 3px; font-size: 12px;
      font-weight: 500; border: 1px solid transparent; color: var(--text-2);
      display: flex; align-items: center; gap: 9px;
      transition: all .15s; letter-spacing: .01em;
    }
    .sidebar .tab:hover { background: var(--card); color: var(--text); border-color: var(--border); }
    .sidebar .tab.active {
      background: var(--primary-dim);
      color: var(--primary);
      border-color: rgba(0,212,255,.25);
      box-shadow: inset 2px 0 0 var(--primary);
    }
    .tab-dot {
      width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0;
      box-shadow: 0 0 5px currentColor;
    }

    /* ── Main ── */
    .main-wrap {
      flex: 1; min-width: 0;
      max-width: 760px;
      padding: 24px 28px;
    }

    /* ── Filter bar ── */
    .filter-bar {
      display: flex; flex-wrap: wrap; gap: 10px; align-items: center;
      margin-bottom: 20px;
    }
    .filter-label {
      font-size: 9px; color: var(--muted); font-weight: 600;
      text-transform: uppercase; letter-spacing: .12em; margin-right: 2px;
      font-family: 'JetBrains Mono', monospace;
    }
    .date-controls { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
    .date-input {
      padding: 5px 10px; background: var(--surface); border: 1px solid var(--border);
      border-radius: 4px; color: var(--text); font-size: 11px;
      font-family: 'JetBrains Mono', monospace;
      outline: none; cursor: pointer; transition: border-color .2s, box-shadow .2s;
      letter-spacing: .03em;
    }
    .date-input:focus { border-color: var(--primary); box-shadow: 0 0 8px var(--primary-glow); }
    .date-input::-webkit-calendar-picker-indicator { filter: invert(0.4) sepia(1) saturate(3) hue-rotate(170deg); cursor: pointer; }
    .sort-wrap { display: flex; align-items: center; gap: 6px; }
    .sort-select {
      padding: 5px 10px; background: var(--surface); border: 1px solid var(--border);
      border-radius: 4px; color: var(--text); font-size: 11px;
      font-family: 'JetBrains Mono', monospace;
      outline: none; cursor: pointer; transition: border-color .2s;
      letter-spacing: .03em;
    }
    .sort-select:focus { border-color: var(--primary); }

    /* ── Stats bar ── */
    .stats-bar {
      display: flex; gap: 0; margin-bottom: 24px;
      background: var(--surface); border-radius: 4px;
      border: 1px solid var(--border);
      overflow: hidden;
      position: relative;
    }
    .stats-bar::before {
      content: ''; pointer-events: none;
      position: absolute; top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent 0%, var(--primary) 50%, transparent 100%);
      opacity: .4;
    }
    .stat {
      flex: 1; display: flex; flex-direction: column; gap: 4px;
      padding: 16px 20px;
      border-right: 1px solid var(--border);
    }
    .stat:last-child { border-right: none; }
    .stat-val {
      font-size: 24px; font-weight: 700; color: var(--primary);
      letter-spacing: -.5px; font-family: 'JetBrains Mono', monospace;
      text-shadow: 0 0 16px rgba(0,212,255,.4);
    }
    .stat-key {
      font-size: 9px; color: var(--muted); text-transform: uppercase;
      letter-spacing: .12em; font-family: 'JetBrains Mono', monospace;
    }

    /* ── Feed ── */
    .feed { display: flex; flex-direction: column; gap: 12px; }

    /* corner brackets on cards */
    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 4px; padding: 18px 20px;
      transition: border-color .25s, background .25s, box-shadow .25s;
      position: relative;
    }
    .card::before, .card::after,
    .card .corner-br, .card .corner-tl-inner {
      content: ''; position: absolute;
      width: 10px; height: 10px; pointer-events: none;
    }
    .card::before {
      top: -1px; right: -1px;
      border-top: 2px solid var(--border);
      border-right: 2px solid var(--border);
    }
    .card::after {
      bottom: -1px; left: -1px;
      border-bottom: 2px solid var(--border);
      border-left: 2px solid var(--border);
    }
    .card:hover {
      border-color: rgba(0,212,255,.2);
      background: var(--card-hover);
      box-shadow: 0 0 0 1px rgba(0,212,255,.1), 0 4px 32px rgba(0,0,0,.5), 0 0 24px rgba(0,212,255,.06);
    }
    .card:hover::before { border-color: var(--primary); }
    .card:hover::after  { border-color: var(--primary); }

    .card-header { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 13px; }
    .avatar {
      width: 38px; height: 38px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 13px; flex-shrink: 0; color: #fff;
      border: 1.5px solid rgba(255,255,255,.15);
    }
    .person-info { flex: 1; min-width: 0; }
    .person-name {
      font-weight: 600; font-size: 14px; color: var(--text);
      display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    }
    .person-meta { font-size: 11px; color: var(--text-2); margin-top: 2px; letter-spacing: .01em; }
    .badge {
      display: inline-flex; align-items: center;
      padding: 2px 8px; border-radius: 2px; font-size: 9px; font-weight: 700;
      letter-spacing: .08em; flex-shrink: 0; text-transform: uppercase;
      font-family: 'JetBrains Mono', monospace;
      background: transparent !important;
      border: 1px solid;
    }
    .card-date {
      font-size: 10px; color: var(--muted); white-space: nowrap; margin-top: 2px;
      font-family: 'JetBrains Mono', monospace; letter-spacing: .04em;
    }

    .card-body {
      font-size: 14px; color: var(--text-2); line-height: 1.75;
      margin-bottom: 14px; white-space: pre-line;
    }
    .card-body .read-more {
      color: var(--primary); font-size: 12px; cursor: pointer;
      display: inline; font-weight: 600; letter-spacing: .04em;
    }
    .card-body .read-more:hover { text-shadow: 0 0 8px var(--primary); }

    .card-footer {
      display: flex; align-items: center; gap: 18px; padding-top: 12px;
      border-top: 1px solid var(--border);
    }
    .metric {
      display: flex; align-items: center; gap: 5px;
      font-size: 11px; color: var(--muted);
      font-family: 'JetBrains Mono', monospace; letter-spacing: .02em;
    }
    .metric svg { flex-shrink: 0; }
    .metric strong { color: var(--text-2); font-weight: 600; }
    .card-link {
      margin-left: auto; font-size: 10px; color: var(--primary);
      display: flex; align-items: center; gap: 4px; font-weight: 600;
      opacity: .6; transition: opacity .15s, text-shadow .15s;
      font-family: 'JetBrains Mono', monospace; letter-spacing: .06em;
      text-transform: uppercase;
    }
    .card-link:hover { opacity: 1; text-shadow: 0 0 8px var(--primary); }

    /* ── Empty state ── */
    .empty { text-align: center; padding: 80px 20px; color: var(--muted); }
    .empty svg { margin-bottom: 16px; opacity: .2; }
    .empty p { font-size: 13px; font-family: 'JetBrains Mono', monospace; letter-spacing: .04em; }

    /* ── Config banner ── */
    .config-banner {
      display: flex; align-items: center; gap: 12px;
      background: rgba(0,212,255,.04); border: 1px solid rgba(0,212,255,.15);
      border-radius: 4px; padding: 12px 16px; margin-bottom: 20px;
      font-size: 12px; color: rgba(0,212,255,.7);
    }
    .config-banner a { color: var(--primary); text-decoration: underline; }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .sidebar { display: none; }
      .main-wrap { padding: 16px; }
      .stats-bar { flex-wrap: wrap; }
      .filter-bar { flex-direction: column; align-items: flex-start; }
      .date-controls { flex-wrap: wrap; }
    }
  </style>
</head>
<body>

<!-- ═══════════ HEADER ═══════════ -->
<header>
  <div class="logo">
    <div class="logo-icon">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="2"/><path d="M16.24 7.76a6 6 0 0 1 0 8.49m-8.48-.01a6 6 0 0 1 0-8.49m11.31-2.82a10 10 0 0 1 0 14.14m-14.14 0a10 10 0 0 1 0-14.14"/>
      </svg>
    </div>
    <span class="logo-text">GTM</span><span class="logo-sub">&nbsp;RADAR</span>
  </div>
  <div class="search-wrap">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
    </svg>
    <input type="text" id="searchInput" placeholder="Search posts or people…" />
  </div>
  <div class="header-right">
    <button class="pill-btn active" id="last7Btn" onclick="toggleLast7()">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
      Last 7 days
    </button>
    <span id="postCount" style="font-size:13px;color:var(--muted)"></span>
  </div>
</header>

<div class="app-body">

<!-- ═══════════ SIDEBAR ═══════════ -->
<nav class="sidebar" id="sidebar">
  <div class="sidebar-label">Function</div>
  <!-- tabs injected by JS -->
</nav>

<div class="main-wrap">

  <!-- Config banner (shown when no sheet URL is set) -->
  <div class="config-banner" id="configBanner" style="display:none">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
    <span>Running on mock data. To connect your sheet: publish it as CSV, then set <code>SHEET_CSV_URL</code> at the top of this file's script. <a href="#" onclick="document.getElementById('configBanner').style.display='none';return false">Dismiss</a></span>
  </div>

  <!-- ── Filter bar ── -->
  <div class="filter-bar">
    <div class="date-controls">
      <span class="filter-label">From</span>
      <input type="date" class="date-input" id="dateFrom" onchange="applyFilters()" />
      <span class="filter-label">To</span>
      <input type="date" class="date-input" id="dateTo" onchange="applyFilters()" />
    </div>
    <div class="sort-wrap" style="margin-left:auto">
      <span class="filter-label">Sort</span>
      <select class="sort-select" id="sortSelect" onchange="applyFilters()">
        <option value="engagement">Top Engagement</option>
        <option value="date">Most Recent</option>
        <option value="likes">Most Likes</option>
        <option value="comments">Most Comments</option>
      </select>
    </div>
  </div>

  <!-- ── Stats ── -->
  <div class="stats-bar" id="statsBar">
    <div class="stat"><div class="stat-val" id="sTotalPosts">—</div><div class="stat-key">Posts</div></div>
    <div class="stat"><div class="stat-val" id="sPeople">—</div><div class="stat-key">People</div></div>
    <div class="stat"><div class="stat-val" id="sTotalLikes">—</div><div class="stat-key">Total Likes</div></div>
    <div class="stat"><div class="stat-val" id="sAvgEng">—</div><div class="stat-key">Avg Engagement</div></div>
  </div>

  <!-- ── Feed ── -->
  <div class="feed" id="feed"></div>
  <div class="empty" id="emptyState" style="display:none">
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
    <p>No posts match your current filters.</p>
  </div>

</div><!-- end main-wrap -->
</div><!-- end app-body -->

<script>
/* ═══════════════════════════════════════════════════
   CONFIG — paste your Google Sheet published CSV URL
   File → Share → Publish to web → Sheet "posts" → CSV
   ═══════════════════════════════════════════════════ */
const SHEET_CSV_URL = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vR-Oy6B5OGnEeiWMFfSmUTA9eA7QXe3jNqfEJ9a8HWd_0EIOr1qlaHCmnXD1XA_W--38UhmZ3CO0hYB/pub?gid=336027905&single=true&output=csv';

/* ── Function definitions ── */
const FUNCTIONS = [
  { key: 'All',                 label: 'All',                  color: '#00d4ff' },
  { key: 'ABM',                 label: 'ABM',                  color: '#a855f7' },
  { key: 'Demand Generation',   label: 'Demand Gen',           color: '#3b82f6' },
  { key: 'SEO',                 label: 'SEO',                  color: '#00ff88' },
  { key: 'Performance Marketing', label: 'Performance',        color: '#f59e0b' },
  { key: 'CRO',                 label: 'CRO',                  color: '#ff4d6d' },
  { key: 'Field Marketing',     label: 'Field',                color: '#00d4ff' },
  { key: 'Community Marketing', label: 'Community',            color: '#ec4899' },
  { key: 'Product Marketing',   label: 'Product Mkt',          color: '#f97316' },
];

function fnColor(fn) {
  const f = FUNCTIONS.find(f => f.key === fn);
  return f ? f.color : '#64748b';
}

/* ── Avatar colours (deterministic by name) ── */
const AVATAR_COLORS = ['#00d4ff','#a855f7','#00ff88','#f59e0b','#ff4d6d','#3b82f6','#ec4899','#f97316','#22d3ee'];
function avatarColor(name) {
  let h = 0;
  for (let c of name) h = (h * 31 + c.charCodeAt(0)) & 0xffffffff;
  return AVATAR_COLORS[Math.abs(h) % AVATAR_COLORS.length];
}
function initials(name) {
  return name.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase();
}

/* ── Date helpers ── */
function daysBetween(d1, d2) {
  return Math.round((d2 - d1) / (1000 * 60 * 60 * 24));
}
function fmtDate(dateStr) {
  const d = new Date(dateStr);
  const diff = daysBetween(d, new Date());
  if (diff === 0) return 'Today';
  if (diff === 1) return 'Yesterday';
  if (diff < 7)  return `${diff} days ago`;
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: diff > 300 ? 'numeric' : undefined });
}
function toISO(dateStr) {
  // handles both YYYY-MM-DD and MM/DD/YYYY
  if (!dateStr) return '';
  if (dateStr.includes('-')) return dateStr;
  const [m, d, y] = dateStr.split('/');
  return `${y}-${m.padStart(2,'0')}-${d.padStart(2,'0')}`;
}
function fmtNum(n) {
  n = parseInt(n) || 0;
  if (n >= 1000) return (n / 1000).toFixed(1) + 'k';
  return n.toString();
}

/* ══════════════════════════════════════════
   MOCK DATA  — mirrors the Google Sheet schema
   Columns: post_id, person_name, linkedin_username,
            function, company, post_content,
            post_date, likes, comments, shares, post_url
   ══════════════════════════════════════════ */
