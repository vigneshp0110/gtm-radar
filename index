/* ── App state ── */
let allPosts = [];
let activeFunc = 'All';
let last7Active = true;

/* ── Init ── */
async function init() {
  if (SHEET_CSV_URL) {
    document.getElementById('configBanner').style.display = 'none';
    try {
      allPosts = await loadFromSheet(SHEET_CSV_URL);
    } catch(e) {
      console.warn('Sheet load failed, falling back to mock data:', e.message);
      allPosts = MOCK_POSTS;
      // Show a soft warning banner
      const b = document.getElementById('configBanner');
      b.style.display = 'flex';
      b.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span>Couldn't reach your sheet in this preview — showing mock data. <strong>It will work correctly when opened in Chrome or deployed to Vercel.</strong> <a href="#" onclick="document.getElementById('configBanner').style.display='none';return false">Dismiss</a></span>`;
    }
  } else {
    allPosts = MOCK_POSTS;
  }
  buildFuncTabs();
  applyFilters();
}

/* ── Load CSV from Google Sheet ── */
async function loadFromSheet(url) {
  // Try direct fetch first, then fall back to CORS proxy
  let text;
  try {
    const res = await fetch(url, { cache: 'no-cache' });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    text = await res.text();
  } catch (e) {
    // Try via CORS proxy
    const proxy = 'https://corsproxy.io/?' + encodeURIComponent(url);
    const res2 = await fetch(proxy, { cache: 'no-cache' });
    if (!res2.ok) throw new Error(`Proxy HTTP ${res2.status}`);
    text = await res2.text();
  }
  return parseCSV(text);
}

/* ── Parse CSV (handles quoted fields with commas/newlines) ── */
function parseCSV(text) {
  const rows = [];
  let row = [], field = '', inQuotes = false;
  for (let i = 0; i < text.length; i++) {
    const ch = text[i], next = text[i + 1];
    if (inQuotes) {
      if (ch === '"' && next === '"') { field += '"'; i++; }
      else if (ch === '"') inQuotes = false;
      else field += ch;
    } else {
      if (ch === '"') inQuotes = true;
      else if (ch === ',') { row.push(field.trim()); field = ''; }
      else if (ch === '\n' || (ch === '\r' && next === '\n')) {
        row.push(field.trim()); rows.push(row); row = []; field = '';
        if (ch === '\r') i++;
      } else field += ch;
    }
  }
  if (field || row.length) { row.push(field.trim()); rows.push(row); }
  const [header, ...data] = rows.filter(r => r.some(c => c));
  return data.map(row => {
    const obj = {};
    header.forEach((h, i) => obj[h.trim()] = row[i] ?? '');
    return obj;
  });
}

/* ── Build function tabs (sidebar) ── */
function buildFuncTabs() {
  const presentFuncs = new Set(allPosts.map(p => p.function));
  const sidebar = document.getElementById('sidebar');
  // keep the label, rebuild everything after it
  sidebar.innerHTML = '<div class="sidebar-label">Function</div>';
  FUNCTIONS.forEach(f => {
    if (f.key !== 'All' && !presentFuncs.has(f.key)) return;
    const btn = document.createElement('button');
    btn.className = 'tab' + (f.key === activeFunc ? ' active' : '');
    const dot = document.createElement('span');
    dot.className = 'tab-dot';
    dot.style.background = f.color;
    btn.appendChild(dot);
    btn.appendChild(document.createTextNode(f.label));
    btn.onclick = () => {
      activeFunc = f.key;
      document.querySelectorAll('.sidebar .tab').forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
      applyFilters();
    };
    sidebar.appendChild(btn);
  });
}

/* ── Main filter + render ── */
function applyFilters() {
  const search   = document.getElementById('searchInput').value.toLowerCase();
  const dateFrom = document.getElementById('dateFrom').value;
  const dateTo   = document.getElementById('dateTo').value;
  const sort     = document.getElementById('sortSelect').value;

  let posts = [...allPosts];

  // Function filter
  if (activeFunc !== 'All') posts = posts.filter(p => p.function === activeFunc);

  // Last 7 days
  if (last7Active) {
    const cutoff = new Date(); cutoff.setDate(cutoff.getDate() - 7);
    posts = posts.filter(p => new Date(toISO(p.post_date)) >= cutoff);
  }

  // Date range
  if (dateFrom) posts = posts.filter(p => toISO(p.post_date) >= dateFrom);
  if (dateTo)   posts = posts.filter(p => toISO(p.post_date) <= dateTo);

  // Search
  if (search) posts = posts.filter(p =>
    p.person_name.toLowerCase().includes(search) ||
    p.post_content.toLowerCase().includes(search) ||
    p.company.toLowerCase().includes(search)
  );

  // Sort
  posts.sort((a, b) => {
    if (sort === 'date')     return new Date(toISO(b.post_date)) - new Date(toISO(a.post_date));
    if (sort === 'likes')    return (parseInt(b.likes)||0) - (parseInt(a.likes)||0);
    if (sort === 'comments') return (parseInt(b.comments)||0) - (parseInt(a.comments)||0);
    // default: engagement = likes + comments + shares
    const engB = (parseInt(b.likes)||0) + (parseInt(b.comments)||0) + (parseInt(b.shares)||0);
    const engA = (parseInt(a.likes)||0) + (parseInt(a.comments)||0) + (parseInt(a.shares)||0);
    return engB - engA;
  });

  updateStats(posts);
  renderFeed(posts);
  document.getElementById('postCount').textContent = posts.length + ' posts';
}

/* ── Stats ── */
function updateStats(posts) {
  const people = new Set(posts.map(p => p.person_name)).size;
  const totalLikes = posts.reduce((s, p) => s + (parseInt(p.likes)||0), 0);
  const avgEng = posts.length
    ? Math.round(posts.reduce((s, p) => s + (parseInt(p.likes)||0) + (parseInt(p.comments)||0) + (parseInt(p.shares)||0), 0) / posts.length)
    : 0;
  document.getElementById('sTotalPosts').textContent = posts.length;
  document.getElementById('sPeople').textContent = people;
  document.getElementById('sTotalLikes').textContent = fmtNum(totalLikes);
  document.getElementById('sAvgEng').textContent = fmtNum(avgEng);
}

/* ── Render feed ── */
function renderFeed(posts) {
