    <div class="card">
      <div class="card-header">
        <div class="avatar" style="background:${aColor}22;color:${aColor};border-color:${aColor}55;text-shadow:0 0 8px ${aColor}88">${initials(p.person_name)}</div>
        <div class="person-info">
          <div class="person-name">
            ${escHtml(p.person_name)}
            <span class="badge" style="color:${color};border-color:${color};box-shadow:0 0 6px ${color}33">${escHtml(p.function)}</span>
          </div>
          <div class="person-meta">${escHtml(p.company)} · ${fmtDate(toISO(p.post_date))}</div>
        </div>
        <div class="card-date">${toISO(p.post_date)}</div>
      </div>
      <div class="card-body" id="${id}">
        ${escHtml(shortContent).replace(/\n/g, '<br>')}
        ${needsTrunc ? `<span class="read-more" onclick="expandPost('${id}', ${JSON.stringify(content)})"> Read more</span>` : ''}
      </div>
      <div class="card-footer">
        <div class="metric">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
          <strong>${fmtNum(p.likes)}</strong>&nbsp;Likes
        </div>
        <div class="metric">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          <strong>${fmtNum(p.comments)}</strong>&nbsp;Comments
        </div>
        <div class="metric">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
          <strong>${fmtNum(p.shares)}</strong>&nbsp;Shares
        </div>
        <div class="metric" style="color:${color}">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
          <strong style="color:${color}">${fmtNum(eng)}</strong>&nbsp;Total
        </div>
        ${p.post_url ? `<a class="card-link" href="${escHtml(p.post_url)}" target="_blank" rel="noopener">
          View on LinkedIn
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>` : ''}
      </div>
    </div>`;
  }).join('');
}

function expandPost(id, fullContent) {
  document.getElementById(id).innerHTML = escHtml(fullContent).replace(/\n/g, '<br>');
}

function escHtml(str) {
  return String(str || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

/* ── Last 7 toggle ── */
function toggleLast7() {
  last7Active = !last7Active;
  document.getElementById('last7Btn').classList.toggle('active', last7Active);
  if (last7Active) {
    document.getElementById('dateFrom').value = '';
    document.getElementById('dateTo').value = '';
  }
  applyFilters();
}

/* ── Search debounce ── */
let searchTimer;
document.getElementById('searchInput').addEventListener('input', () => {
  clearTimeout(searchTimer);
  searchTimer = setTimeout(applyFilters, 250);
});

/* ── Date range clears last 7 ── */
['dateFrom','dateTo'].forEach(id => {
  document.getElementById(id).addEventListener('change', () => {
    if (document.getElementById(id).value) {
      last7Active = false;
      document.getElementById('last7Btn').classList.remove('active');
    }
  });
});

/* ── Boot ── */
